    "test:api": "turbo run test --filter=@remark42/api",
    "coverage:api": "turbo run coverage --filter=@remark42/api",
    "type-check:api": "turbo run type-check --filter=@remark42/api",
    "lint:api": "turbo run lint --filter=@remark42/api"
  },
