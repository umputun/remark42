{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "dev": {},
    "start": {},
    "build": {
      "outputs": ["public/**"]
    },
    "lint": {
      "inputs": ["**/*.tsx", "**/*.ts", "**/*.css"]
    },
    "lint:styles": {
      "inputs": ["**/*.css"]
    },
    "lint:scripts": {
      "inputs": ["**/*.tsx", "**/*.ts"]
    },
    "test": {
      "inputs": ["**/*.tsx", "**/*.ts"]
    },
    "coverage": {
      "inputs": ["**/*.tsx", "**/*.ts"]
    },
    "type-check": {
      "inputs": ["**/*.tsx", "**/*.ts"]
    },
    "format": {}
  }
}
